{
  "name": "kinefit",
  "private": true,
  "version": "2.1.0",
  "type": "module",
  "scripts": {
    "build": "echo 'Progetto Mobile-only. Nessuna build web richiesta.'",
    "lint": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate": "npm run mobile:typecheck",
    "release": "node scripts/release.js",
    "release:ci": "semantic-release",
    "release:semantic": "standard-version",
    "db:sync-exercises": "python scripts/extract_data.py --sync",
    "db:gen-types": "supabase gen types typescript --local > src/types/database.types.ts && prettier --write src/types/database.types.ts",
    "mobile:install": "cd mobile && npm install",
    "mobile:dev": "cd mobile && npx expo start",
    "mobile:lint": "cd mobile && npx eslint .",
    "mobile:typecheck": "cd mobile && npx tsc",
    "mobile:build": "cd mobile && npx eas build -p android --profile preview",
    "maintenance:depcheck": "depcheck",
    "maintenance:update": "ncu",
    "prepare": "husky"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.0",
    "@tanstack/react-query": "^5.67.2",
    "@tanstack/react-query-devtools": "^5.67.2",
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.21",
    "framer-motion": "^12.39.0",
    "idb": "^8.0.3",
    "loglevel": "^1.9.2",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.15.1",
    "recharts": "^3.8.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@babel/core": "^7.29.0",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@rolldown/plugin-babel": "^0.2.3",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.6",
    "@semantic-release/npm": "^12.0.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/babel__core": "^7.20.5",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "babel-plugin-react-compiler": "^1.0.0",
    "depcheck": "^1.4.7",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^26.0.0",
    "lint-staged": "^15.4.3",
    "npm-check-updates": "^22.2.1",
    "prettier": "^3.5.3",
    "semantic-release": "^24.2.9",
    "standard-version": "^9.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^3.2.4",
    "vitest-axe": "^0.1.0"
  },
  "overrides": {
    "@vitest/mocker": {
      "vite": "$vite"
    }
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{js,css,md,json}": [
      "prettier --write"
    ]
  }
}
